# =============================================================================
#  Polaris Relay - Variables d'environnement (modèle)
#  Copié en .env par install.sh, puis complété avec les valeurs générées.
#  NE JAMAIS committer le .env réel (voir .gitignore).
# =============================================================================

# --- Ports publics (Internet) ---------------------------------------------
SRTLA_PORT=5000          # UDP - entrée SRTLA depuis les smartphones (IRL Pro)
SRT_PORT=8890            # UDP - SRT MediaMTX (publication directe + lecture OBS)
HLS_PORT=8888            # TCP - HLS (option)
WEBRTC_PORT=8889         # TCP/UDP - WebRTC (option)

# --- Admin (bindés sur Tailscale uniquement) -------------------------------
# Rempli automatiquement par install.sh via `tailscale ip -4`.
# Si vide, les interfaces admin retombent sur 127.0.0.1 (local only).
TS_IP=

# --- Clés MediaMTX (générées par scripts/genkeys.sh) -----------------------
# Clé de PUBLICATION (caméras IRL Pro)
MTX_PUBLISH_USER=polaris
MTX_PUBLISH_PASS=

# Clé de LECTURE (OBS / régie)
MTX_READ_USER=obs
MTX_READ_PASS=

# --- Versions d'images -----------------------------------------------------
# MediaMTX épinglé sur une version stable connue (évite qu'une maj de schéma
# casse le démarrage). Vérifier/monter la version après test.
MEDIAMTX_TAG=v1.19.2
SRTLA_REF=main

# --- Watchtower ------------------------------------------------------------
# Cron 6 champs (sec min heure jour mois jour-semaine). Défaut : 04h00 chaque nuit.
WATCHTOWER_SCHEDULE=0 0 4 * * *
